# Postgres connection string used by the app at runtime (Prisma Client).
# Use the pooled connection string from your hosted Postgres provider
# (e.g. Neon/Supabase "pooled" connection, or PgBouncer).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Direct (non-pooled) connection string, used by Prisma Migrate to run
# migrations. Required when DATABASE_URL points at a connection pooler.
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth (Auth.js)
# Base URL of the deployed app, e.g. https://your-app.vercel.app
NEXTAUTH_URL="https://your-app.vercel.app"
# Random secret used to sign session tokens — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Google OAuth (used for student sign-in) - see README.md for setup steps.
# Add the production redirect URI in the Google Cloud Console:
# https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Signing secret shared with the video call platform
LIVE_OPENGRAPES_JWT_SECRET="generate-a-secure-random-key"
# URL of the video call platform (http://localhost:3001 for local, or https://live.opengrapes.com)
MEETING_PLATFORM_URL="http://localhost:3001"
# API URL of the video call platform backend (http://localhost:3001 for local, or https://api.live.opengrapes.com)
MEETING_PLATFORM_API_URL="http://localhost:3001"
